{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Market Recap Canonical Schema",
  "type": "object",
  "required": [
    "date",
    "market",
    "summary",
    "themes",
    "performance",
    "watchlist",
    "risks",
    "actions"
  ],
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "market": {
      "type": "string",
      "description": "例如 CN-A, US, HK"
    },
    "summary": {
      "type": "string"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "performance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "value"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": [
              "number",
              "string"
            ]
          },
          "unit": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "watchlist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "thesis"
        ],
        "properties": {
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "thesis": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "risk": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta": {
      "type": "object"
    }
  }
}
